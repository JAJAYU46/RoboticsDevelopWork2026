<launch>

    <node pkg="imu_utils" type="imu_an" name="imu_an" output="screen">
        <!-- IMU Topic Name -->
        <param name="imu_topic" type="string" value= "/mo_camera/imu"/> 
        <!-- The generated files head title name -->
        <param name="imu_name" type="string" value= "myMono"/> 
        <param name="data_save_path" type="string" value= "$(find imu_utils)/data/"/>
        <!-- The bag time length, need to be lower then the bag recorded time [minutes] -->
        <param name="max_time_min" type="int" value= "120"/> 
        <param name="max_cluster" type="int" value= "100"/>
    </node>

·

</launch>
